# Production environment template.
# Copy to .env on the deployment host and replace every CHANGE_ME value.
# Never commit the real .env file.

# Public HTTPS entrypoint
APP_HOSTNAME=rag.example.com

# Runtime mode
DEV_MODE=false

# PostgreSQL
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_POSTGRES_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_LONG_RANDOM_REDIS_PASSWORD

# API authentication
SECRET_KEY=CHANGE_ME_64_PLUS_CHARACTER_RANDOM_JWT_SECRET
ADMIN_PASSWORD=CHANGE_ME_LONG_RANDOM_INITIAL_ADMIN_PASSWORD
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Optional Keycloak integration, if enabled later
KEYCLOAK_URL=https://auth.example.com
KEYCLOAK_REALM=rag
KEYCLOAK_CLIENT_ID=rag-api
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_KEYCLOAK_CLIENT_SECRET

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Local generation and embeddings
OLLAMA_BASE_URL=http://ollama:11434
LOCAL_LLM_BASE_URL=http://ollama:11434/v1
LOCAL_LLM_MODEL=llama3.2:3b
EMBEDDING_MODEL=bge-m3:latest
EMBEDDING_DIMENSION=1024

# Dedicated judge model
JUDGE_LLM_BASE_URL=http://judge-ollama:11434
JUDGE_MODEL=llama3.2:3b
JUDGE_TIMEOUT_SECONDS=60
JUDGE_SCORE_THRESHOLD=0.7
JUDGE_ENABLED=true

# Observability
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_LONG_RANDOM_GRAFANA_PASSWORD

# OCR
OCR_LANG=ar
OCR_DEVICE=gpu
