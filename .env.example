# Local development template.
# Copy to .env for local Docker runs only. Do not use these defaults in production.
# For production, start from .env.production.example instead.

# PostgreSQL
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
DATABASE_URL=postgresql+asyncpg://raguser:ragpassword@localhost:5432/ragdb

# Redis
REDIS_PASSWORD=1234
CELERY_BROKER_URL=redis://:1234@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:1234@localhost:6379/1

# Dev mode (skips Keycloak)
DEV_MODE=true
DEV_USER_ID=dev-user-001
DEV_USER_EMAIL=dev@example.com

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
EMBEDDING_MODEL=bge-m3:latest
EMBEDDING_DIMENSION=1024
GENERATION_MODEL=llama3.2:3b
LOCAL_LLM_MODEL=llama3.2:3b
LOCAL_LLM_BASE_URL=http://ollama:11434/v1
LOCAL_LLM_QUANTIZATION=4-bit
LOCAL_LLM_HOSTING=ollama
JUDGE_LLM_BASE_URL=http://judge-ollama:11434
JUDGE_MODEL=llama3.2:3b
JUDGE_TIMEOUT_SECONDS=60
JUDGE_SCORE_THRESHOLD=0.7
JUDGE_ENABLED=true

# Keycloak (unused in dev mode)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=rag
KEYCLOAK_CLIENT_ID=rag-api
KEYCLOAK_CLIENT_SECRET=secret


# NER microservice
NER_SERVICE_URL=http://localhost:8001
